NODE_ENV=development

# --- Docker Compose (корень репо: docker-compose.yml) ---
# Запуск API + Postgres + Redis:  docker compose up -d --build
# Миграции один раз:              docker compose --profile migrate run --rm prisma-migrate
# Локально (из корня репо):        npm run prisma:migrate  (нужен DATABASE_URL в .env)
# Порты наружу (при конфликтах):  POSTGRES_PORT=5433 REDIS_PUBLISH_PORT=6380 PORT=3001
# В контейнере api DATABASE_URL собирается из POSTGRES_USER/PASSWORD/DB — задай их в .env
#
# docker-compose.dev.yml — только postgres + redis; api-go с хоста. Файл .env.dev (не в git): POSTGRES_*, опционально REDIS_PASSWORD.
# Пример:  docker compose -f docker-compose.dev.yml --env-file .env.dev up -d

# Список origin через запятую. Нужен для REST и Socket.IO (/socket.io, неймспейсы /chat и /support).
CORS_ORIGIN=http://localhost:3000

# Swagger: в production по умолчанию выключен; включить: ENABLE_SWAGGER=true
ENABLE_SWAGGER=

# Go api-go: Redis (сессии auth: session:<id>, verify-phone:, forgot-password:)
REDIS_PASSWORD=
# Go api-go: Swagger UI — http://localhost:<PORT>/docs/index.html (в спеке host 3000; при другом PORT в Try it out подставь свой URL).
# Обновить OpenAPI после правок cmd/server/docs_swagger.go:
#   cd api-go && go run github.com/swaggo/swag/cmd/swag@latest init -g main.go -o ./docs -d ./cmd/server --parseInternal

BASE_URL=
# --- Внешние интеграции (api-go) ---
# SMTP_*     — письма: восстановление пароля (auth), верификация почты (user/go: user verify-email)
# MTS_TOKEN  — SMS при регистрации ?where=sms (Bearer к api.mts.ru)
# NOTISEND_* — канал ?where=telegram: NOTISEND_API_KEY + NOTISEND_PROJECT (по умолчанию torgui_sam)
# TINKOFF_*  — инициализация платежа / callback
# S3_*       — аватары, фото товаров, баннеры
# DADATA_API_KEY — /address/* (подсказки и валидация)
DADATA_API_KEY=

# Database config
DATABASE_URL=

# Postgres config
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Redis config (сессии, коды SMS)
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379

# SMTP config
SMTP_HOST=
# use 465 for secure connections
SMTP_PORT=587 
# set to true if using port 465
SMTP_SECURE=false
# Аналог rejectUnauthorized: false — только для SMTP с самоподписанным/кривым сертификатом
SMTP_TLS_INSECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# S3 config
S3_ENDPOINT=
S3_BUCKET_NAME=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
# Опционально: публичный префикс URL объектов (S3)
S3_PUBLIC_BASE=

# Payment config
TINKOFF_TERMINAL_KEY=   
TINKOFF_SECRET_KEY=

# SMS / Notisend (регистрация /auth/sign-up ?where=sms|telegram)
MTS_TOKEN=
NOTISEND_API_KEY=
# Слаг проекта в Notisend (дефолт torgui_sam)
NOTISEND_PROJECT=torgui_sam
